---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nouvelle demande d'AGE - KoproGo">
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Nouvelle demande d'AGE</h1>
        <p class="text-gray-600 mt-2">
          Initier une demande d'assemblée générale extraordinaire
        </p>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <p class="text-gray-500">
          Formulaire de demande d'AGE — requires 1/5 des quotes-parts (Art. 3.87 §2 CC)
        </p>
      </div>

      <div class="mt-6">
        <a href="/age-requests" class="inline-flex items-center text-primary-600 hover:text-primary-700">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Retour aux demandes d'AGE
        </a>
      </div>
    </div>
  </div>
</Layout>
