---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marketplace - Corps de métier - KoproGo">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Marketplace</h1>
      <p class="text-gray-600 mt-2">
        Annuaire des prestataires agréés pour votre copropriété
      </p>
    </div>

    <div data-testid="marketplace-list">
      <div class="bg-white rounded-lg shadow p-6">
        <p class="text-gray-500">
          Recherchez des prestataires par corps de métier (plomberie, électricité, nettoyage, etc.)
        </p>
      </div>
    </div>
  </div>
</Layout>
