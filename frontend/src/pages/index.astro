---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPosts = posts
	.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
	.slice(0, 3);

const categoryLabels: Record<string, string> = {
	'syndic': 'Syndic',
	'coproprietaire': 'Copropriétaire',
	'assemblee-generale': 'Assemblée Générale',
	'comptabilite': 'Comptabilité',
	'locataire': 'Locataire',
	'conseil-copropriete': 'Conseil de Copropriété',
	'notaire': 'Notaire',
	'rgpd': 'RGPD',
	'acp': 'ACP',
};

const categoryColors: Record<string, string> = {
	'syndic': 'bg-blue-100 text-blue-800',
	'coproprietaire': 'bg-emerald-100 text-emerald-800',
	'assemblee-generale': 'bg-purple-100 text-purple-800',
	'locataire': 'bg-rose-100 text-rose-800',
	'conseil-copropriete': 'bg-indigo-100 text-indigo-800',
	'notaire': 'bg-cyan-100 text-cyan-800',
	'acp': 'bg-teal-100 text-teal-800',
};
---

<Layout title="KoproGo - Gestion de Copropriété SaaS" showNav={false} showFooter={false}>
	<!-- Navigation bar -->
	<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
		<div class="container mx-auto px-4 py-4 flex items-center justify-between">
			<a href="/" class="text-2xl font-bold text-primary-700">KoproGo</a>
			<nav class="flex items-center gap-6">
				<a href="#features" class="text-gray-600 hover:text-primary-700 transition hidden md:inline">Fonctionnalités</a>
				<a href="#ideas" class="text-gray-600 hover:text-primary-700 transition hidden md:inline">Idées clés</a>
				<a href="/blog" class="text-gray-600 hover:text-primary-700 transition">Blog</a>
				<a href="#youtube" class="text-gray-600 hover:text-primary-700 transition hidden md:inline">YouTube</a>
				<a
					href="/login"
					class="px-5 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-medium"
				>
					Se connecter
				</a>
			</nav>
		</div>
	</header>

	<main>
		<!-- Hero section -->
		<section class="bg-gradient-to-br from-primary-50 via-white to-emerald-50 py-20 lg:py-28">
			<div class="container mx-auto px-4 max-w-5xl text-center">
				<h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
					La copropriété belge,<br/>
					<span class="text-primary-700">simplifiée et conforme</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
					Plateforme SaaS open-source pour syndics, comptables et copropriétaires.
					Conforme au Code civil belge, au PCMN et au RGPD.
				</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<a
						href="/login"
						class="px-8 py-4 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition font-semibold text-lg shadow-lg"
					>
						Accéder à la plateforme
					</a>
					<a
						href="/blog"
						class="px-8 py-4 bg-white text-primary-700 border-2 border-primary-200 rounded-lg hover:border-primary-400 transition font-semibold text-lg"
					>
						Lire le blog juridique
					</a>
				</div>
				<p class="mt-8 text-sm text-gray-400">
					Architecture Hexagonale · Rust · Actix-web · PostgreSQL · Astro · Svelte
				</p>
			</div>
		</section>

		<!-- Key ideas section -->
		<section id="ideas" class="py-16 bg-white">
			<div class="container mx-auto px-4 max-w-5xl">
				<h2 class="text-3xl font-bold text-gray-900 text-center mb-4">Nos idées clés</h2>
				<p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
					KoproGo est né d'un constat : la gestion de copropriété en Belgique manque d'outils modernes, transparents et conformes.
				</p>
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#9878;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Conformité légale native</h3>
						<p class="text-gray-600 text-sm">
							Chaque fonctionnalité est construite sur les articles du Code civil belge.
							109 règles légales documentées, tracées du code au texte de loi.
						</p>
					</div>
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#128101;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Transparence totale</h3>
						<p class="text-gray-600 text-sm">
							Accès en ligne 24/7 aux documents, PV et comptabilité.
							Comme l'exige l'art. 3.89 §5, points 9 et 11.
						</p>
					</div>
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#128200;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Comptabilité PCMN</h3>
						<p class="text-gray-600 text-sm">
							Plan comptable minimum normalisé belge intégré (AR 12/07/2012).
							~90 comptes pré-configurés, double entrée, bilan et compte de résultats.
						</p>
					</div>
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#128274;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">RGPD by design</h3>
						<p class="text-gray-600 text-sm">
							Articles 15 à 21 implémentés : accès, rectification, effacement,
							restriction de traitement, opposition au marketing.
						</p>
					</div>
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#127760;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Open source</h3>
						<p class="text-gray-600 text-sm">
							Code source ouvert sur GitHub. Auditable par tous.
							Pas de vendor lock-in, pas de boîte noire.
						</p>
					</div>
					<div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
						<div class="w-12 h-12 bg-teal-100 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">&#127793;</span>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Éco-conception</h3>
						<p class="text-gray-600 text-sm">
							Cible &lt; 0.5g CO2 par requête. Architecture Rust optimisée,
							latence P99 &lt; 5ms, empreinte mémoire &lt; 128 Mo.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Features section -->
		<section id="features" class="py-16 bg-gray-50">
			<div class="container mx-auto px-4 max-w-5xl">
				<h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Fonctionnalités</h2>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
					{[
						{ title: 'Assemblées générales', desc: 'Convocations, votes, PV, quorum, majorités', icon: '&#128227;' },
						{ title: 'Comptabilité', desc: 'PCMN belge, budget, bilan, appels de fonds', icon: '&#128202;' },
						{ title: 'Paiements', desc: 'Stripe, SEPA, relances automatisées', icon: '&#128179;' },
						{ title: 'Documents', desc: 'Stockage, archivage, accès en ligne', icon: '&#128193;' },
						{ title: 'Maintenance', desc: 'Tickets, devis entrepreneurs, inspections', icon: '&#128295;' },
						{ title: 'Communauté', desc: 'SEL, partage, sondages, gamification', icon: '&#129309;' },
						{ title: 'Énergie', desc: 'Achats groupés, compteurs IoT, Linky', icon: '&#9889;' },
						{ title: 'Sécurité', desc: '2FA, chiffrement, audit, monitoring', icon: '&#128737;' },
					].map(f => (
						<div class="bg-white rounded-lg p-5 shadow-sm hover:shadow-md transition">
							<div class="text-2xl mb-2" set:html={f.icon}></div>
							<h3 class="font-semibold text-gray-900 mb-1">{f.title}</h3>
							<p class="text-sm text-gray-600">{f.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Blog preview section -->
		<section id="blog" class="py-16 bg-white">
			<div class="container mx-auto px-4 max-w-5xl">
				<div class="flex items-center justify-between mb-10">
					<div>
						<h2 class="text-3xl font-bold text-gray-900">Blog juridique</h2>
						<p class="text-gray-600 mt-2">Guide pratique de la copropriété belge</p>
					</div>
					<a href="/blog" class="text-primary-700 hover:text-primary-800 font-medium transition hidden md:inline">
						Tous les articles &rarr;
					</a>
				</div>
				<div class="grid gap-8 md:grid-cols-3">
					{latestPosts.map(post => (
						<a href={`/blog/${post.id}`} class="group bg-white border border-gray-200 rounded-xl hover:shadow-lg transition-shadow overflow-hidden">
							<div class="p-6">
								<div class="flex items-center gap-2 mb-3">
									<span class={`px-2 py-0.5 rounded-full text-xs font-medium ${categoryColors[post.data.category] || 'bg-gray-100 text-gray-800'}`}>
										{categoryLabels[post.data.category] || post.data.category}
									</span>
								</div>
								<h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition mb-2 line-clamp-2">
									{post.data.title}
								</h3>
								<p class="text-sm text-gray-600 line-clamp-3">
									{post.data.description}
								</p>
							</div>
						</a>
					))}
				</div>
				<div class="mt-8 text-center md:hidden">
					<a href="/blog" class="text-primary-700 hover:text-primary-800 font-medium transition">
						Tous les articles &rarr;
					</a>
				</div>
			</div>
		</section>

		<!-- YouTube section -->
		<section id="youtube" class="py-16 bg-gray-50">
			<div class="container mx-auto px-4 max-w-5xl">
				<div class="text-center mb-10">
					<h2 class="text-3xl font-bold text-gray-900 mb-4">KoproGo sur YouTube</h2>
					<p class="text-gray-600 max-w-2xl mx-auto">
						Tutoriels, démos et explications juridiques en vidéo.
						Suivez le développement de la plateforme en direct.
					</p>
				</div>
				<!-- Playlist embed -->
				<div class="rounded-xl overflow-hidden shadow-lg mb-8">
					<div class="relative w-full" style="padding-bottom: 56.25%;">
						<iframe
							class="absolute inset-0 w-full h-full"
							src="https://www.youtube-nocookie.com/embed/videoseries?si=mTtmmByojlHISmph&list=PLBxLivSdjkRtGNabcvJuV68_9_VFmGVc-"
							title="KoproGo - Playlist YouTube"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							referrerpolicy="strict-origin-when-cross-origin"
							allowfullscreen
						></iframe>
					</div>
				</div>
				<div class="text-center">
					<a
						href="https://www.youtube.com/@KoproGo"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium"
					>
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
							<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
						</svg>
						Voir toutes les vidéos
					</a>
				</div>
			</div>
		</section>

		<!-- CTA section -->
		<section class="py-16 bg-primary-700">
			<div class="container mx-auto px-4 max-w-3xl text-center">
				<h2 class="text-3xl font-bold text-white mb-4">Prêt à simplifier votre copropriété ?</h2>
				<p class="text-primary-100 mb-8 text-lg">
					Rejoignez les syndics et copropriétaires qui utilisent KoproGo
					pour une gestion transparente et conforme.
				</p>
				<a
					href="/login"
					class="inline-block px-8 py-4 bg-white text-primary-700 rounded-lg hover:bg-primary-50 transition font-semibold text-lg shadow-lg"
				>
					Commencer maintenant
				</a>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-gray-900 text-gray-400 py-10">
		<div class="container mx-auto px-4 max-w-5xl">
			<div class="grid gap-8 md:grid-cols-3 mb-8">
				<div>
					<h3 class="text-white font-semibold mb-3">KoproGo</h3>
					<p class="text-sm">
						Plateforme SaaS open-source de gestion de copropriété,
						conçue pour le droit belge.
					</p>
				</div>
				<div>
					<h3 class="text-white font-semibold mb-3">Liens utiles</h3>
					<ul class="space-y-2 text-sm">
						<li><a href="/blog" class="hover:text-white transition">Blog juridique</a></li>
						<li><a href="/mentions-legales" class="hover:text-white transition">Mentions légales</a></li>
						<li><a href="/settings/gdpr" class="hover:text-white transition">RGPD</a></li>
						<li><a href="https://github.com/gilmry/koprogo" target="_blank" rel="noopener noreferrer" class="hover:text-white transition">GitHub</a></li>
					</ul>
				</div>
				<div>
					<h3 class="text-white font-semibold mb-3">Suivez-nous</h3>
					<ul class="space-y-2 text-sm">
						<li><a href="https://www.youtube.com/@KoproGo" target="_blank" rel="noopener noreferrer" class="hover:text-white transition">YouTube</a></li>
						<li><a href="https://github.com/gilmry/koprogo" target="_blank" rel="noopener noreferrer" class="hover:text-white transition">GitHub</a></li>
					</ul>
				</div>
			</div>
			<div class="border-t border-gray-800 pt-6 text-center text-sm">
				<p>&copy; 2025 KoproGo - Gestion de Copropriété SaaS</p>
			</div>
		</div>
	</footer>
</Layout>
