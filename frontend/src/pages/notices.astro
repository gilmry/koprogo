---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tableau d'affichage - KoproGo">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">📌 Annonces</h1>
        <p class="text-gray-600 mt-1">Annonces communautaires et petites annonces</p>
      </div>
      <button
        id="create-notice-btn"
        class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
        data-testid="notices-create-btn"
      >
        + Créer une annonce
      </button>
    </div>

    <div id="building-selector-container" class="mb-6"></div>
    <div id="notice-list-container"></div>
    <div id="create-modal-container"></div>
  </div>
</Layout>

<script>
  import { mount, unmount } from "svelte";
  import NoticeList from "../components/notices/NoticeList.svelte";
  import NoticeCreateModal from "../components/notices/NoticeCreateModal.svelte";
  import BuildingSelector from "../components/BuildingSelector.svelte";
  import { getMyOwner } from "../lib/api";

  let currentOwnerId = "";

  const selectorContainer = document.getElementById("building-selector-container");
  const listContainer = document.getElementById("notice-list-container");
  const modalContainer = document.getElementById("create-modal-container");
  let listComponent: any = null;
  let createModalComponent: any = null;
  let currentBuildingId = "";

  function mountList(buildingId: string) {
    currentBuildingId = buildingId;
    if (!listContainer) return;
    if (listComponent) { try { unmount(listComponent); } catch {} }
    listContainer.innerHTML = "";
    listComponent = mount(NoticeList as any, {
      target: listContainer,
      props: { buildingId, showFilters: true },
    });
  }

  function closeModal() {
    if (createModalComponent) {
      try { unmount(createModalComponent); } catch {}
      createModalComponent = null;
      if (modalContainer) modalContainer.innerHTML = "";
    }
  }

  function openModal() {
    if (!currentBuildingId) return;
    closeModal();
    if (modalContainer) {
      createModalComponent = mount(NoticeCreateModal as any, {
        target: modalContainer,
        props: {
          isOpen: true,
          buildingId: currentBuildingId,
          authorId: currentOwnerId,
          onClose: closeModal,
          onSuccess: () => {
            window.location.reload();
          },
        },
      });
    }
  }

  async function init() {
    const owner = await getMyOwner();
    if (owner) {
      currentOwnerId = owner.id;
    }

    if (selectorContainer) {
      mount(BuildingSelector as any, {
        target: selectorContainer,
        props: {
          label: "Immeuble",
          onSelect: (id: string) => mountList(id),
        },
      });
    }
  }

  init();

  const createBtn = document.getElementById("create-notice-btn");
  if (createBtn) {
    createBtn.addEventListener("click", openModal);
  }
</script>
