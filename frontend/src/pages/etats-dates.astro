---
import Layout from '../layouts/Layout.astro';
import EtatDateList from '../components/etats-dates/EtatDateList.svelte';
---

<Layout title="États Datés" showNav={true} requireAuth={true}>
  <div class="max-w-7xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">États Datés</h1>
      <p class="text-gray-600 mt-1">
        Document légal obligatoire lors de la vente d'un lot en copropriété.
        Contient la situation financière du lot et de la copropriété (16 sections légales).
      </p>
      <div class="mt-3 p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-800">
        <strong>Délai légal :</strong> Maximum 15 jours ouvrables pour fournir l'état daté au notaire.
        Les demandes de plus de 10 jours sont signalées en retard.
      </div>
    </div>
    <EtatDateList client:load />
  </div>
</Layout>
