# Development Dockerfile with hot reload (Astro dev server)
FROM node:22-slim

WORKDIR /app

# Copy package files for dependency caching
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm install

# Install Playwright Chromium + system deps (same as CI)
# Needed for: npm run test:e2e, npm run test:scenarios
RUN npx playwright install chromium --with-deps

# Source code will be mounted via volume

# Expose Astro dev server port
EXPOSE 3000

# Hot reload command: Astro dev server with HMR
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
