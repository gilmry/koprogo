      "Edit(frontend/Dockerfile)",
      "Edit(backend/src/infrastructure/database/seed.rs)",
      "Edit(backend/Cargo.toml)",
      "Edit(frontend/package.json)",
      "Write(backend/migrations/**)",
      "Write(infrastructure/**/*.tf)",
      "Write(.github/workflows/**)"
    ],

