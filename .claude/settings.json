      "Bash(kubectl cordon:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl cp:*)",
      "Bash(argocd app sync:*)",
      "Bash(argocd app delete:*)",
      "Bash(argocd app create:*)",
      "Bash(argocd app set:*)",
      "Bash(argocd login:*)",
      "Bash(velero backup delete:*)",
      "Bash(velero restore:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(docker push:*)",
      "Bash(docker rmi:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker volume prune:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh api * -X DELETE:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)",
      "Bash(:(){ :|: & };::*)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)",
      "Edit(**/.env.staging)",
      "Edit(**/.env.loadtest)",
      "Edit(infrastructure/_shared/secrets/**)",
      "Edit(**/age.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "Edit(**/.vault_pass)",
      "Edit(**/kubeconfig)",
      "Edit(**/*.tfstate)",
      "Edit(**/*.tfstate.backup)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Write(**/.env.staging)",
      "Write(infrastructure/_shared/secrets/**)",
      "Write(**/age.key)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.vault_pass)"
    ],

    "_comment_ask": "Actions sensibles : approbation humaine systematique. L'agent doit invoquer /human-review pour expliquer avant d'agir.",
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout main:*)",
      "Bash(git checkout master:*)",
      "Bash(git checkout production:*)",
      "Bash(git checkout staging:*)",
      "Bash(git tag:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh workflow run:*)",
      "Bash(make migrate:*)",
      "Bash(make migrate-create:*)",
      "Bash(sqlx migrate run:*)",
      "Bash(sqlx migrate revert:*)",
      "Bash(sqlx migrate add:*)",
      "Bash(make docker-build:*)",
      "Bash(docker build:*)",
      "Bash(docker compose down:*)",
      "Bash(docker-compose down:*)",
      "Edit(backend/migrations/**)",
      "Edit(infrastructure/**/*.tf)",
      "Edit(infrastructure/**/values.yaml)",
      "Edit(infrastructure/**/values-*.yaml)",
      "Edit(infrastructure/**/helm-values.yaml)",
      "Edit(.github/workflows/**)",
      "Edit(.github/dependabot.yml)",
      "Edit(CLAUDE.md)",
      "Edit(docker-compose.yml)",
