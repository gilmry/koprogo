      "Bash(terraform show:*)",
      "Bash(terraform output:*)",
      "Bash(tflint:*)",
      "Bash(tfsec:*)",
      "Bash(checkov:*)",
      "Bash(ansible-lint:*)",
      "Bash(ansible-playbook --check:*)",
      "Bash(ansible-playbook --syntax-check:*)",
      "Bash(helm lint:*)",
